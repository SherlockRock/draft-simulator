{
  "name": "draft-simulator",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter draft-simulator-frontend --filter draft-simulator-backend dev",
    "dev:frontend": "pnpm --filter draft-simulator-frontend dev",
    "dev:backend": "pnpm --filter draft-simulator-backend dev",
    "lint": "pnpm --filter draft-simulator-frontend lint",
    "build": "pnpm --filter @draft-sim/shared-types build && pnpm --filter draft-simulator-frontend build",
    "build:types": "pnpm --filter @draft-sim/shared-types build",
    "typecheck": "pnpm --filter draft-simulator-frontend exec tsc --noEmit",
    "update-champion-meta": "node scripts/scrape-meraki.mjs && node scripts/scrape-cdragon.mjs && node scripts/compile-champion-meta.mjs && node scripts/compile-matchup-data.mjs && node scripts/validate-compiled-data.mjs",
    "update-champions": "node scripts/update-champions.mjs",
    "update-images": "node scripts/update-champion-images.mjs",
    "test:match-pipeline": "node --test scripts/match-pipeline/*.test.mjs",
    "match-pipeline:smoke": "node scripts/match-pipeline/smoke.mjs",
    "test:ugg-scraper": "node --test scripts/ugg-scraper/*.test.mjs",
    "ugg:scrape-rankings": "node scripts/ugg-scraper/scrape-rankings.mjs",
    "ugg:scrape-matchups": "node scripts/ugg-scraper/scrape-matchups.mjs"
  },
  "devDependencies": {
    "sharp": "^0.34.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ]
  }
}
