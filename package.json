{
  "name": "draft-simulator",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter draft-simulator-frontend --filter draft-simulator-backend dev",
    "dev:frontend": "pnpm --filter draft-simulator-frontend dev",
    "dev:backend": "pnpm --filter draft-simulator-backend dev",
    "build": "pnpm --filter @draft-sim/shared-types build && pnpm --filter draft-simulator-frontend build",
    "build:types": "pnpm --filter @draft-sim/shared-types build",
    "typecheck": "pnpm --filter draft-simulator-frontend exec tsc --noEmit",
    "update-champions": "node scripts/update-champions.mjs",
    "update-images": "node scripts/update-champion-images.mjs"
  },
  "devDependencies": {
    "sharp": "^0.34.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ]
  }
}
